{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/reconcile", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/pulse", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/nightly", "schedule": "7 21 * * *" }
  ]
}
