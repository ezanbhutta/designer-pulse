# ── Browser (Vite) ────────────────────────────────────────────────────────────
# Safe to expose: anon key is protected by Row-Level Security.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Server-only (Vercel env vars — never shipped to the browser) ─────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ClickUp personal API token (or app token) with read access to the
# "Designers Team" space (id 90187090116).
CLICKUP_API_TOKEN=pk_...
# Shared secret returned by ClickUp when the webhook is created; used to
# verify X-Signature on every webhook delivery.
CLICKUP_WEBHOOK_SECRET=...
# ClickUp workspace (team) id — used for webhook management endpoints.
CLICKUP_TEAM_ID=...

# Bearer secret that protects the cron + admin endpoints
# (Vercel Cron sends it automatically when set as CRON_SECRET).
CRON_SECRET=generate-a-long-random-string
